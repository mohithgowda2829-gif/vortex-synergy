# Backend runtime environment for staging/production.
# You can use either a provider-style DATABASE_URL or explicit JDBC settings.

SPRING_PROFILES_ACTIVE=prod
PORT=8080

# Option A: provider-style URL. Preferred on Render.
# Example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
DATABASE_URL=

# Option B: explicit JDBC settings. Use this on hosts that give you separate values.
DB_URL=jdbc:postgresql://YOUR_DB_HOST:5432/YOUR_DB_NAME?sslmode=require
DB_USERNAME=YOUR_DB_USERNAME
DB_PASSWORD=YOUR_DB_PASSWORD

# Generate a long random base64/string secret before deployment.
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRATION_HOURS=24

EXPOSE_PASSWORD_RESET_TOKEN=false
PASSWORD_RESET_TOKEN_HOURS=1

# Add your deployed Flutter web/laptop origin if you deploy web.
# Native Android/iOS apps do not rely on browser CORS, but web does.
CORS_ALLOWED_ORIGIN_PATTERNS=https://YOUR_WEB_APP_DOMAIN.com,http://localhost:*,http://127.0.0.1:*

FOOD_SAFE_WINDOW_HOURS=4
CLAIM_RESERVATION_HOURS=4
CLAIM_FAIRNESS_WINDOW_DAYS=7
EXPIRY_CHECK_MS=300000

# On Render Docker services, a persistent disk is commonly mounted under /app/storage.
# Without a persistent disk, uploaded photos will be lost on restart/redeploy.
UPLOAD_DIR=/app/storage/uploads
